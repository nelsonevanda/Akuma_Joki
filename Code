<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AKUMA JOKI</title>

<style>

body{
margin:0;
font-family:Arial;
background:#fff;
overflow:hidden;
}

/* BACKGROUND */
.bg{
position:fixed;
inset:0;
background:
radial-gradient(circle at 20% 20%, rgba(140,82,255,0.22), transparent 40%),
radial-gradient(circle at 80% 80%, rgba(140,82,255,0.22), transparent 40%),
radial-gradient(circle at 50% 50%, rgba(140,82,255,0.10), transparent 60%);
z-index:-3;
}

/* FRAME */
.frame{
position:fixed;
inset:0;
border:2px solid rgba(140,82,255,0.25);
pointer-events:none;
z-index:-2;
}

.frame::before,
.frame::after{
content:"";
position:absolute;
width:120px;
height:120px;
border:3px solid #8c52ff;
filter:drop-shadow(0 0 10px #8c52ff);
}

.frame::before{
top:20px;
left:20px;
border-right:none;
border-bottom:none;
}

.frame::after{
bottom:20px;
right:20px;
border-left:none;
border-top:none;
}

/* LAYOUT */
#home{
height:100vh;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
text-align:center;
position:relative;
}

/* LOGO (SUDAH DIPAKAI GAMBAR KAMU) */
.logo{
width:280px;
max-width:80%;
margin-bottom:15px;
filter:drop-shadow(0 0 18px #8c52ff);
}

/* TEXT */
.sub{
color:#444;
margin-bottom:30px;
font-size:14px;
}

/* BUTTON RING */
.btn-wrap{
position:relative;
display:inline-block;
}

.btn-wrap::before{
content:"";
position:absolute;
inset:-18px;
border-radius:50%;
border:3px solid transparent;
border-top:3px solid #8c52ff;
border-right:3px solid #8c52ff;
animation:spin 2s linear infinite;
filter:drop-shadow(0 0 10px #8c52ff);
}

button{
padding:14px 40px;
border:none;
border-radius:30px;
background:#8c52ff;
color:white;
font-weight:bold;
cursor:pointer;
}

/* SPIN */
@keyframes spin{
to{transform:rotate(360deg);}
}

/* PARTICLE */
.particle{
position:absolute;
width:6px;
height:6px;
background:#8c52ff;
border-radius:50%;
opacity:0.5;
animation:float 6s linear infinite;
}

@keyframes float{
0%{transform:translateY(0);opacity:0;}
30%{opacity:0.6;}
100%{transform:translateY(-100vh);opacity:0;}
}

</style>
</head>

<body>

<div class="bg"></div>
<div class="frame"></div>

<section id="home">

<!-- LOGO FIX LANGSUNG DARI GAMBAR KAMU -->
<img src="/mnt/data/IMG-20260705-WA3224(3).jpg" class="logo">

<div class="sub">
Jasa Joki Game Terpercaya
</div>

<div class="btn-wrap">
<button onclick="masukMenu()">PILIH GAME</button>
</div>

</section>

<script>

/* PARTICLE */
for(let i=0;i<25;i++){
let p=document.createElement("div");
p.className="particle";
p.style.left=Math.random()*100+"%";
p.style.bottom="-10px";
p.style.animationDuration=(4+Math.random()*6)+"s";
document.body.appendChild(p);
}

function masukMenu(){
alert("LANJUT PART 2");
}

</script>



</body>
</html>
