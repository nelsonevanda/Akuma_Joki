<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AKUMA JOKI</title>

<style>
body{
margin:0;
font-family:Arial;
background:linear-gradient(180deg,#2b0c55,#12001f);
color:white;
}

header{
text-align:center;
padding:40px 20px;
}

h1{
margin:0;
font-size:48px;
text-shadow:0 0 20px #8c52ff;
}

.sub{
color:#d8c8ff;
margin-top:5px;
}

.stats{
display:flex;
justify-content:center;
gap:10px;
flex-wrap:wrap;
padding:20px;
}

.card{
background:#24103d;
border:1px solid #8c52ff;
padding:15px;
border-radius:15px;
width:150px;
text-align:center;
}

.games{
padding:10px;
text-align:center;
}

.btn{
display:block;
margin:10px auto;
width:260px;
padding:12px;
background:#3a1b66;
border:1px solid #8c52ff;
border-radius:10px;
cursor:pointer;
transition:.2s;
}

.btn:hover{
background:#8c52ff;
}

.section{
max-width:900px;
margin:auto;
padding:20px;
}

.box{
background:#1e0f33;
border:1px solid #8c52ff;
padding:15px;
border-radius:12px;
margin-top:10px;
}

.item{
display:flex;
justify-content:space-between;
padding:8px;
border-bottom:1px solid #2d1a4a;
cursor:pointer;
}

.item:hover{
background:#2a1550;
}

footer{
text-align:center;
padding:30px;
color:#aaa;
margin-top:40px;
}
</style>

<script>
const wa = "6282131561301";

function order(game,item,price){
let text =
`Bang saya mau joki game ${game}

List jokian yang saya order

USN :
PW :

Jokian : ${item}
Harga : ${price}`;

window.open("https://wa.me/" + wa + "?text=" + encodeURIComponent(text), "_blank");
}
</script>

</head>

<body>

<header>
<h1>⚔️ AKUMA JOKI ⚔️</h1>
<div class="sub">Jasa Joki Terpercaya</div>
</header>

<div class="stats">
<div class="card"><b>1582+</b><br>Total Order</div>
<div class="card"><b>99.8%</b><br>Berhasil</div>
<div class="card"><b>4.9⭐</b><br>Rating</div>
</div>

<div class="games">
<div class="btn">🎮 BLOX FRUITS</div>
<div class="btn">🧊 EXPEDITION ANTARCTICA</div>
<div class="btn">🏪 RETAIL TYCOON 2</div>
</div>

<div class="section">

<h2>BLOX FRUITS</h2>

<div class="box">
<div class="item" onclick="order('Blox Fruits','100 Level','2K')">
<span>100 Level</span><span>2K</span>
</div>

<div class="item" onclick="order('Blox Fruits','200 Level','4K')">
<span>200 Level</span><span>4K</span>
</div>

<div class="item" onclick="order('Blox Fruits','CDK','20K')">
<span>CDK</span><span>20K</span>
</div>

<div class="item" onclick="order('Blox Fruits','Raid 1-10','10K')">
<span>Raid 1-10</span><span>10K</span>
</div>
</div>

<h2>EXPEDITION ANTARCTICA</h2>

<div class="box">
<div class="item" onclick="order('Expedition Antarctica','Muncak 1-10','15K')">
<span>Muncak 1-10</span><span>15K</span>
</div>

<div class="item" onclick="order('Expedition Antarctica','Muncak 1-25','30K')">
<span>Muncak 1-25</span><span>30K</span>
</div>

<div class="item" onclick="order('Expedition Antarctica','Selesai semua misi NPC (bawah tempat awal)','25K')">
<span>Selesai NPC</span><span>25K</span>
</div>
</div>

<h2>RETAIL TYCOON 2</h2>

<div class="box">
<div class="item" onclick="order('Retail Tycoon 2','Bener Toko','15K')">
<span>Bener Toko</span><span>15K</span>
</div>

<div class="item" onclick="order('Retail Tycoon 2','Baru Main - Toko Bagus','25K')">
<span>Baru Main → Toko Bagus</span><span>25K</span>
</div>
</div>

</div>

<footer>
© AKUMA JOKI
</footer>

</body>
</html>
